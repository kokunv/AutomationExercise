<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Regression Suite">

    <test name="Regression Tests">

        <groups>
            <run>
                <include name="login"/>
                <include name="signup"/>
                <include name="negative"/>
                <include name="positive"/>
            </run>
        </groups>

        <classes>
            <class name="com.automation.exercise.selenium.tests.LoginTest"/>
            <class name="com.automation.exercise.selenium.tests.SignUpTest"/>
        </classes>

    </test>

</suite>