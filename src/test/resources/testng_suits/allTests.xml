<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Automation Suite" parallel="tests" thread-count="2">

    <test name="Login Tests">
        <groups>
            <run>
                <include name="login"/>
            </run>
        </groups>

        <classes>
            <class name="com.automation.exercise.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Signup Tests">
        <groups>
            <run>
                <include name="signup"/>
            </run>
        </groups>

        <classes>
            <class name="com.automation.exercise.tests.SignUpTest"/>
        </classes>
    </test>

</suite>